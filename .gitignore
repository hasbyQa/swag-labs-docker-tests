# ── Maven build output ──────────────────────────────────────────
# The 'target' folder is generated by Maven — never commit it.
# It contains compiled .class files, JARs, test reports, etc.
target/

# ── IDE-specific files ──────────────────────────────────────────
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.eclipse/
.classpath
.project
.settings/

# VS Code
.vscode/

# ── OS-generated files ──────────────────────────────────────────
.DS_Store        # macOS finder metadata
Thumbs.db        # Windows thumbnail cache

# ── Environment / secrets ───────────────────────────────────────
# Never commit credentials or local environment configs
.env
*.env.local

# ── Test artifacts ──────────────────────────────────────────────
# Screenshots or logs generated during test runs (local only)
screenshots/
logs/
